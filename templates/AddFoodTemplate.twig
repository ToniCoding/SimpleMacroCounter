<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="{{ asset('img/favicon.ico') }}" type="image/x-icon">
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
    <title>New intake - SMC</title>
</head>

<body>
    <div class="page">

        <header class="header">
            <div class="logo">
                <h3><a href="/">SimpleMacroCounter</a></h3>
            </div>

            <div class="navigation">
                <ul class="nav-desktop">
                    <li><a href="/modifyMacros?action=increase">Add macros</a></li>
                    <li><a href="/modifyMacros?action=reduce">Reduce macros</a></li>
                    <li><a href="/history">History</a></li>
                    <li><a href="/foods">Register foods</a></li>
                    <li><a href="/addfood">Register intake</a></li>
                    <li><a href="/settings">Settings</a></li>
                    <li><a href="/logout">Logout</a></li>
                </ul>

                <button class="hamburger-menu" aria-label="Menú">
                    <img src="{{ asset('img/menu.png') }}" alt="Menu" height="24" width="24">
                </button>

                <ul class="nav-mobile">
                    <li><a href="/modifyMacros?action=increase"><img src="{{ asset('img/up_arrow.png') }}" height="32" width="32">Add
                            macros</a></li>
                    <li><a href="/modifyMacros?action=reduce"><img src="{{ asset('img/down_arrow.png') }}" height="32"
                                width="32">Reduce Macros</a></li>
                    <li><a href="/history"><img src="{{ asset('img/history_icon.png') }}" height="32"
                                width="32">History</a></li>
                    <li><a href="/foods"><img src="{{ asset('img/vegetable.png') }}" height="32" width="32">Register
                            foods</a></li>
                    <li><a href="/addfood"><img src="{{ asset('img/burger.png') }}" height="32" width="32">Register
                            intake</a></li>
                    <li><a href="/settings"><img src="{{ asset('img/settings_icon.png') }}" height="32"
                                width="32">Settings</a>
                    </li>
                    <li><a href="/logout"><img src="{{ asset('img/logout_icon.png') }}" height="32"
                                width="32">Logout</a></li>
                </ul>
            </div>
        </header>

        <main class="intake-layout">

            <!-- =========================
             LEFT SIDE
        ========================== -->
            <section class="intake-left">

                <!-- SEARCH -->
                <input class="form-input table-search" type="text" id="search-bar-food" placeholder="Search food..." />

                <!-- =========================
                 DESKTOP TABLE
            ========================== -->
                <div class="foodTable">
                    <table class="food-search-table">
                        <thead>
                            <tr>
                                <th>Food</th>
                                <th>Market</th>
                                <th>Calories</th>
                                <th>Protein</th>
                                <th>Carbs</th>
                                <th>Fats</th>
                                <th>Fiber</th>
                            </tr>
                        </thead>

                        <tbody id="foodFoundRegistries" class="food-search-table-body"></tbody>
                    </table>
                </div>

                <!-- =========================
                 MOBILE CARDS
            ========================== -->
                <div class="foodTableMobile">
                    <div id="foodMobileList"></div>
                </div>

            </section>

            <!-- =========================
             RIGHT PANEL
        ========================== -->
            <section class="intake-right">
                <div class="intake-card">

                    <p id="selected-food-name" class="intake-title">
                        Select a food
                    </p>

                    <div class="intake-macros">
                        <p id="macro-1"></p>
                        <p id="macro-2"></p>
                        <p id="macro-3"></p>
                        <p id="macro-4"></p>
                        <p id="macro-5"></p>
                    </div>

                    <input class="form-input" type="text" id="grams" placeholder="Intake grams" />

                    <button id="intake-submit-desktop" class="btn-submit" type="button">
                        Register intake
                    </button>

                </div>
            </section>

        </main>

        <!-- DATA -->
        <div id="foodCatalog" data-config="{{ foodCatalog | json_encode | escape('html_attr') }}">
        </div>

    </div>

    <script>
        const hamburger = document.querySelector('.hamburger-menu');
        const navMobile = document.querySelector('.nav-mobile');
        const overlay = document.createElement('div');
        overlay.className = 'menu-overlay';
        document.body.appendChild(overlay);

        hamburger.addEventListener('click', () => {
            hamburger.classList.toggle('active');
            navMobile.classList.toggle('active');
            overlay.classList.toggle('active');
            document.body.style.overflow = navMobile.classList.contains('active') ? 'hidden' : '';
        });

        overlay.addEventListener('click', () => {
            hamburger.classList.remove('active');
            navMobile.classList.remove('active');
            overlay.classList.remove('active');
            document.body.style.overflow = '';
        });

        document.querySelectorAll('.nav-mobile a').forEach(link => {
            link.addEventListener('click', () => {
                hamburger.classList.remove('active');
                navMobile.classList.remove('active');
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            });
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && navMobile.classList.contains('active')) {
                hamburger.classList.remove('active');
                navMobile.classList.remove('active');
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            }
        });
    </script>
    <script type="module" src="{{ asset('js/utils.js') }}"></script>
    <script type="module" src="{{ asset('js/foodFiltering.js') }}"></script>
    <script type="module" src="{{ asset('js/payloadCreator.js') }}"></script>
</body>

</html>