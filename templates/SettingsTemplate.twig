<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="icon" href="{{ asset('img/favicon.ico') }}" type="image/x-icon">
        <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
        <title>Settings - SMC</title>
    </head>
    <body>
        {% if error %}
            <div class="alert alert-danger">{{ error }}</div>
        {% endif %}
                <header class="header">
            <div class="logo">
                <h3><a href="/">SimpleMacroCounter</a></h3>
            </div>

            <div class="navigation">
                <ul class="nav-desktop">
                    <li><a href="/modifyMacros">Add macros</a></li>
                    <li><a href="/reduceMacros">Reduce macros</a></li>
                    <li><a href="/history">History</a></li>
                    <li><a href="/foods">Register foods</a></li>
                    <li><a href="/addfood">Register intake</a></li>
                    <li><a href="/settings">Settings</a></li>
                    <li><a href="/logout">Logout</a></li>
                </ul>

                <button class="hamburger-menu" aria-label="Menú">
                    <img src="{{ asset('img/menu.png') }}" alt="Menu" height="24" width="24">
                </button>

                <ul class="nav-mobile">
                    <li><a href="/modifyMacros"><img src="{{ asset('img/up_arrow.png') }}" height="32" width="32">Add
                            macros</a></li>
                    <li><a href="/reduceMacros"><img src="{{ asset('img/down_arrow.png') }}" height="32"
                                width="32">Reduce Macros</a></li>
                    <li><a href="/history"><img src="{{ asset('img/history_icon.png') }}" height="32"
                                width="32">History</a></li>
                    <li><a href="/foods"><img src="{{ asset('img/vegetable.png') }}" height="32" width="32">Register
                            foods</a></li>
                    <li><a href="/addfood"><img src="{{ asset('img/burger.png') }}" height="32" width="32">Register
                            intake</a></li>
                    <li><a href="/settings"><img src="{{ asset('img/settings_icon.png') }}" height="32" width="32">Settings</a>
                    </li>
                    <li><a href="/logout"><img src="{{ asset('img/logout_icon.png') }}" height="32"
                                width="32">Logout</a></li>
                </ul>
            </div>
        </header>
        <div class="content">
            <div class="form-container">
                <h1 class="page-title">Modify macro-nutrient intake goals</h1>
                
                {{ form_start(form) }}
                    <div class="form-group">
                        <label for="newCalories">New calories goal</label>
                        {{ form_widget(form.newCalories, {'id': 'newCalories', 'attr': {'class': 'form-input'}}) }}
                    </div>
                    
                    <div class="form-group">
                        <label for="newProtein">New protein goal</label>
                        {{ form_widget(form.newProtein, {'id': 'newProtein', 'attr': {'class': 'form-input'}}) }}
                    </div>
                    
                    <div class="form-group">
                        <label for="newCarbs">New carbs goal</label>
                        {{ form_widget(form.newCarbs, {'id': 'newCarbs', 'attr': {'class': 'form-input'}}) }}
                    </div>
                    
                    <div class="form-group">
                        <label for="newFats">New fats goal</label>
                        {{ form_widget(form.newFats, {'id': 'newFats', 'attr': {'class': 'form-input'}}) }}
                    </div>
                    
                    <div class="form-group">
                        <label for="newFiber">New fiber goal</label>
                        {{ form_widget(form.newFiber, {'id': 'newFiber', 'attr': {'class': 'form-input'}}) }}
                    </div>
                    
                    <button type="submit" class="btn-submit">Modify</button>
                {{ form_end(form) }}
            </div>
        </div>
    </body>
        <script>
        const hamburger = document.querySelector('.hamburger-menu');
        const navMobile = document.querySelector('.nav-mobile');
        const overlay = document.createElement('div');
        overlay.className = 'menu-overlay';
        document.body.appendChild(overlay);

        hamburger.addEventListener('click', () => {
            hamburger.classList.toggle('active');
            navMobile.classList.toggle('active');
            overlay.classList.toggle('active');
            document.body.style.overflow = navMobile.classList.contains('active') ? 'hidden' : '';
        });

        overlay.addEventListener('click', () => {
            hamburger.classList.remove('active');
            navMobile.classList.remove('active');
            overlay.classList.remove('active');
            document.body.style.overflow = '';
        });

        document.querySelectorAll('.nav-mobile a').forEach(link => {
            link.addEventListener('click', () => {
                hamburger.classList.remove('active');
                navMobile.classList.remove('active');
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            });
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && navMobile.classList.contains('active')) {
                hamburger.classList.remove('active');
                navMobile.classList.remove('active');
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            }
        });
    </script>
</html>
