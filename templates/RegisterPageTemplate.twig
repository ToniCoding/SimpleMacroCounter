<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="{{ asset('img/favicon.ico') }}" type="image/x-icon">
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
    <title>Register - SMC</title>
</head>

<body>
    {% if error %}
    <div class="alert alert-danger">{{ error }}</div>
    {% endif %}

    <div class="content">
        <div class="form-container">
            <h1 class="page-title">Register</h1>

            {{ form_start(form) }}
            <div class="form-group">
                <label for="username">Username</label>
                {{ form_widget(form.username, {'id': 'username', 'attr': {'class': 'form-input'}}) }}
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                {{ form_widget(form.password, {'id': 'password', 'attr': {'class': 'form-input'}}) }}
            </div>

            <div class="form-group">
                <label for="email">Email</label>
                {{ form_widget(form.email, {'id': 'email', 'attr': {'class': 'form-input'}}) }}
            </div>

            <div class="form-group">
                <label for="alias">Alias</label>
                {{ form_widget(form.alias, {'id': 'alias', 'attr': {'class': 'form-input'}}) }}
            </div>

            <div class="form-group">
                <label for="age">Age</label>
                {{ form_widget(form.age, {'id': 'age', 'attr': {'class': 'form-input'}}) }}
            </div>

            <button type="submit" class="btn-submit">Submit</button>
            {{ form_end(form) }}
        </div>
    </div>
</body>

</html>