<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="icon" href="{{ asset('img/favicon.ico') }}" type="image/x-icon">
        <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
        <title>Home - SMC</title>
    </head>
    <body>
        <div class="navBar">
            <div class="logo">
                <p><a href="/">SimpleMacroCounter</a> <sub style="font-size: 0.9rem;"><i><b>{{ user }}</b></i></sub></p>
            </div>
            <div class="navigation">
                <ul>
                    <li><a href="/modifyMacros">Add macros</a></li>
                    <li><a href="/reduceMacros">Reduce macros</a></li>
                    <li><a href="/history">History</a></li>
                    <li><a href="/logout">Logout</a></li>
                </ul>
            </div>
        </div>
        {% if error|default %}
            <p>{{ error }}</p>
        {% endif %}

        {% for message in app.flashes('successMessages') %}
            <div>{{ message }}</div>
        {% endfor %}

        <div class="macroContainers">
            <div class="macroRow">
                <div class="progressContainer">
                    <p>Protein</p>
                    <progress value="{{ proteinProgress }}" max="100" id="protein"></progress>
                </div>
                <div class="progressContainer">
                    <p>Carbs</p>
                    <progress value="{{ carbProgress }}" max="100" id="carbs"></progress>
                </div>
            </div>
            <div class="macroRow">
                <div class="progressContainer">
                    <p>Fats</p>
                    <progress value="{{ fatProgress }}" max="100" id="fats"></progress>
                </div>
                <div class="progress_container">
                    <p>Fiber</p>
                    <progress value="{{ fiberProgress }}" max="100" id="fiber"></progress>
                </div>
            </div>
            <div class="centered">
                <div class="progressContainer">
                    <p>Calories</p>
                    <progress value="{{ calorieProgress }}" max="100" id="calories"></progress>
                  </div>
            </div>
        </div>
    </body>
</html>
