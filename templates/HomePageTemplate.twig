<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="{{ asset('img/favicon.ico') }}" type="image/x-icon">
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
    <title>Home - SMC</title>
</head>

<body>
    <div class="page">
        <header class="header">
            <div class="logo">
                <h3><a href="/">SimpleMacroCounter</a></h3>
            </div>

            <div class="navigation">
                <ul class="nav-desktop">
                    <li><a href="/modifyMacros?action=increase">Add macros</a></li>
                    <li><a href="/modifyMacros?action=reduce">Reduce macros</a></li>
                    <li><a href="/history">History</a></li>
                    <li><a href="/foods">Register foods</a></li>
                    <li><a href="/addfood">Register intake</a></li>
                    <li><a href="/settings">Settings</a></li>
                    <li><a href="/logout">Logout</a></li>
                </ul>

                <button class="hamburger-menu" aria-label="Menú">
                    <img src="{{ asset('img/menu.png') }}" alt="Menu" height="24" width="24">
                </button>

                <ul class="nav-mobile">
                    <li><a href="/modifyMacros?action=increase"><img src="{{ asset('img/up_arrow.png') }}" height="32" width="32">Add
                            macros</a></li>
                    <li><a href="/modifyMacros?action=reduce"><img src="{{ asset('img/down_arrow.png') }}" height="32"
                                width="32">Reduce Macros</a></li>
                    <li><a href="/history"><img src="{{ asset('img/history_icon.png') }}" height="32"
                                width="32">History</a></li>
                    <li><a href="/foods"><img src="{{ asset('img/vegetable.png') }}" height="32" width="32">Register
                            foods</a></li>
                    <li><a href="/addfood"><img src="{{ asset('img/burger.png') }}" height="32" width="32">Register
                            intake</a></li>
                    <li><a href="/settings"><img src="{{ asset('img/settings_icon.png') }}" height="32" width="32">Settings</a>
                    </li>
                    <li><a href="/logout"><img src="{{ asset('img/logout_icon.png') }}" height="32"
                                width="32">Logout</a></li>
                </ul>
            </div>
        </header>
        <main class="content">
            <div class="text-content">
                <p>Today you consumed <b>{{ calories }}</b> kcals. You are <b>{{ caloricProgress|replace({'-':''})
                    }}</b>{% if calorieProgress >= 100 %} over {% else %} under {% endif %} your goal of {{
                    calorieGoal }} calories (<i>{{ calorieProgress }}%</i>).</p>
            </div>
            {% for message in app.flashes('registerFoodStatus') %}
            <div class="alert alert-success">
                {{ message }}
            </div>
            {% endfor %}
            <div class="text-content progress-wrappers">
                <div class="progress-wrapper">
                    <img src="{{ asset('img/protein_icon.png') }}" width="32" height="32" />

                    <div class="progress-track">
                        <div class="progress-fill" data-progress="{{ proteinProgress }}"></div>
                    </div>

                    <span class="progress-text">{{ proteinGrams }}g / {{ proteinGoal }} <sup><i>goal</sup></i></span>
                </div>
                <div class="progress-wrapper">
                    <img src="{{ asset('img/carbs_icon.png') }}" width="32px" height="32px" />

                    <div class="progress-track">
                        <div class="progress-fill" data-progress="{{ carbProgress }}"></div>
                    </div>

                    <span class="progress-text">{{ carbGrams }}g / {{ carbGoal }} <sup><i>goal</sup></i></span>
                </div>
                <div class="progress-wrapper">
                    <img src="{{ asset('img/fats_icon.png') }}" width="32px" height="32px" />

                    <div class="progress-track">
                        <div class="progress-fill" data-progress="{{ fatProgress }}"></div>
                    </div>

                    <span class="progress-text">{{ fatGrams }}g / {{ fatGoal }} <sup><i>goal</sup></i></span>
                </div>
                <div class="progress-wrapper">
                    <img src="{{ asset('img/fiber_icon.png') }}" width="32px" height="32px" />

                    <div class="progress-track">
                        <div class="progress-fill" data-progress="{{ fiberProgress }}"></div>
                    </div>

                    <span class="progress-text">{{ fiberGrams }}g / {{ fiberGoal }} <sup><i>goal</sup></i></span>
                </div>
            </div>
            <div class="text-content"></div> <!-- Reserved section for future analytics -->
        </main>
    </div>
</body>
<script>
    document.querySelectorAll('.progress-fill').forEach(bar => {
        let p = Math.min(bar.dataset.progress, 100);
        bar.style.width = p + '%';
    });

    const hamburger = document.querySelector('.hamburger-menu');
    const navMobile = document.querySelector('.nav-mobile');
    const overlay = document.createElement('div');
    overlay.className = 'menu-overlay';
    document.body.appendChild(overlay);

    hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('active');
        navMobile.classList.toggle('active');
        overlay.classList.toggle('active');
        document.body.style.overflow = navMobile.classList.contains('active') ? 'hidden' : '';
    });

    overlay.addEventListener('click', () => {
        hamburger.classList.remove('active');
        navMobile.classList.remove('active');
        overlay.classList.remove('active');
        document.body.style.overflow = '';
    });

    document.querySelectorAll('.nav-mobile a').forEach(link => {
        link.addEventListener('click', () => {
            hamburger.classList.remove('active');
            navMobile.classList.remove('active');
            overlay.classList.remove('active');
            document.body.style.overflow = '';
        });
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && navMobile.classList.contains('active')) {
            hamburger.classList.remove('active');
            navMobile.classList.remove('active');
            overlay.classList.remove('active');
            document.body.style.overflow = '';
        }
    });

    document.querySelectorAll('.progress-fill').forEach(bar => {
        let p = Math.min(bar.dataset.progress, 100);
        bar.style.width = p + '%';
    });
</script>

</html>