{
    "name": "anto/simple-macro-counter",
    "description": "SMC is a fitness tracker web app that helps the user reach its objectives",
    "authors": [
        {
            "name": "ToniCoding",
            "email": "antoniovallejo2612@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "7.2.*",
        "symfony/routing": "7.4.13",
        "symfony/dependency-injection": "7.2.*",
        "symfony/console": "7.2.*",
        "symfony/yaml": "7.4.12",
        "symfony/options-resolver": "7.2.*",
        "symfony/security-csrf": "7.2.*",
        "symfony/twig-bundle": "7.2.*",
        "symfony/asset": "7.2.*",
        "symfony/security-bundle": "7.2.*",
        "symfony/form": "7.2.*",
        "symfony/validator": "7.2.*",
        "symfony/runtime": "7.4.12",
        "symfony/dotenv": "7.2.*",
        "doctrine/dbal": "^3.0",
        "doctrine/doctrine-bundle": "^2.16",
        "doctrine/doctrine-migrations-bundle": "^3.4",
        "doctrine/orm": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "src\\": "src/"
        }
    },
    "require-dev": {
        "symfony/maker-bundle": "^1.64",
        "symfony/flex": "^2.8",
        "phpunit/phpunit": "10.5.62",
        "symfony/browser-kit": "7.2.*",
        "symfony/css-selector": "7.2.*",
        "symfony/phpunit-bridge": "7.2.*"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "phpunit": "vendor\\bin\\phpunit"
    }
}
